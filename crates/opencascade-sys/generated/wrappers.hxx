    return std::make_unique<gp_Ax1>(self_.Rotated(theA1, theAngRad));
}
inline std::unique_ptr<gp_Ax1> gp_Ax1_scaled(const gp_Ax1& self_, const gp_Pnt& theP, Standard_Real theS) {
    return std::make_unique<gp_Ax1>(self_.Scaled(theP, theS));
